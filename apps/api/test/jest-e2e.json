{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "moduleNameMapper": {
    "^@wavestream/shared$": "<rootDir>/../../../packages/shared/src",
    "^@wavestream/shared/(.*)$": "<rootDir>/../../../packages/shared/src/$1",
    "^src/(.*)$": "<rootDir>/../src/$1",
    "^test/(.*)$": "<rootDir>/$1"
  },
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  }
}
