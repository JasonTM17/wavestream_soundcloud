# Server
NODE_ENV=development
PORT=4000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=wavestream
DB_PASSWORD=wavestream_secret
DB_NAME=wavestream

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO / S3
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=wavestream
MINIO_SECRET_KEY=wavestream_secret
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=http://localhost:9000

# JWT (CHANGE IN PRODUCTION)
ALLOW_WEAK_LOCAL_SECRETS=true
JWT_ACCESS_SECRET=dev-access-secret-change-me-in-prod-32
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-in-prod-32
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000,http://127.0.0.1:3101
