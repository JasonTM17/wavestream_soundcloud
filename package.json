{
  "name": "wavestream",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "description": "A production-style SoundCloud-inspired music streaming platform built with Next.js, NestJS, PostgreSQL, Redis, MinIO, and Docker.",
  "license": "MIT",
  "author": "Nguyen Son <jasonbmt06@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JasonTM17/Wavestream_Soundcloud.git"
  },
  "homepage": "https://github.com/JasonTM17/Wavestream_Soundcloud#readme",
  "bugs": {
    "url": "https://github.com/JasonTM17/Wavestream_Soundcloud/issues"
  },
  "keywords": [
    "nextjs",
    "nestjs",
    "typescript",
    "soundcloud-clone",
    "music-streaming",
    "postgresql",
    "redis",
    "minio",
    "docker",
    "portfolio-project"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api start:dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "pnpm --filter api test:e2e && pnpm --filter web test:e2e",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm docs:check",
    "audit": "node ./scripts/audit-security.mjs",
    "docs:check": "node ./scripts/check-docs-text.mjs",
    "smoke:docker": "node ./scripts/docker-smoke.mjs",
    "db:migrate": "pnpm --filter api migration:run",
    "db:seed": "pnpm --filter api seed",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,css,md,yml,yaml}\""
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "turbo": "^2.9.5"
  },
  "pnpm": {
    "overrides": {
      "fast-xml-parser": "^5.7.2",
      "postcss": "^8.5.13",
      "typeorm>uuid": "link:packages/uuid-compat"
    }
  }
}
