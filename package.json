{
  "name": "wavestream",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "description": "WaveStream - A modern music streaming platform",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api start:dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "pnpm --filter api test:e2e && pnpm --filter web test:e2e",
    "audit": "node ./scripts/audit-security.mjs",
    "docs:check": "node ./scripts/check-docs-text.mjs",
    "smoke:docker": "node ./scripts/docker-smoke.mjs",
    "db:migrate": "pnpm --filter api migration:run",
    "db:seed": "pnpm --filter api seed",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,css,md,yml,yaml}\""
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "turbo": "^2.9.5"
  },
  "pnpm": {
    "overrides": {
      "fast-xml-parser": "^5.7.2",
      "postcss": "^8.5.13"
    }
  }
}
