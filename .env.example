# Database
NODE_ENV=development
PORT=4000
DB_USER=wavestream
DB_PASSWORD=wavestream_secret
DB_NAME=wavestream
DB_HOST=localhost
DB_PORT=5432
POSTGRES_HOST_PORT=5433

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO
MINIO_ENDPOINT=localhost
MINIO_ROOT_USER=wavestream
MINIO_ROOT_PASSWORD=wavestream_secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=http://localhost:9000

# JWT Secrets (CHANGE THESE IN PRODUCTION)
ALLOW_WEAK_LOCAL_SECRETS=true
JWT_ACCESS_SECRET=change-me-access-secret-must-be-32-chars-or-more
JWT_REFRESH_SECRET=change-me-refresh-secret-must-be-32-chars-or-more
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Frontend / App
FRONTEND_URL=http://localhost:3000,http://127.0.0.1:3101
NEXT_PUBLIC_API_URL=http://localhost:4000
INTERNAL_API_URL=http://localhost:4000
NEXT_PUBLIC_MINIO_URL=http://localhost:9000

# SMTP / Mailpit
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=WaveStream <noreply@wavestream.local>
SMTP_USER=
SMTP_PASSWORD=
MAILPIT_WEB_PORT=8025

# Seeded admin
ADMIN_EMAIL=admin@wavestream.local
ADMIN_PASSWORD=Admin123!
ADMIN_DISPLAY_NAME=WaveStream Admin
ADMIN_USERNAME=wavestream-admin
DEFAULT_CREATOR_ROLE=creator

# Ports
API_PORT=4000
WEB_PORT=3000
